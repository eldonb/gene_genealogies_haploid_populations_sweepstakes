int main (int argc, const char * argv[])
{

setup_rng(static_cast<unsigned int>(atoi(argv[argc-1])));

 /* ALPHA - KAPPA - CEPS - RHO */
 /* check range */
  assert(atof(argv[1]) > std::numeric_limits<double>::epsilon());
  assert(atof(argv[1]) < 1.);
  assert(2. <= atof(argv[2]));
  assert(0. <=  atof(argv[3]) );
 
  approximate(atof(argv[1]),  atof(argv[2]), atof(argv[3]), atof(argv[4]));  
  gsl_rng_free(rngtype);

  return GSL_SUCCESS;
}


