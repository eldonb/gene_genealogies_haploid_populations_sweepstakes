@ {\bf descending factorial ${(x)}_{m}$}

the descending factorial  ${(x)}_{m} \equiv x(x-1)\cdots (x-m+1)$


<<deltanull-poissondirichlet-varyingN.c>>=
static double descending_factorial(const double x, const double m)
{
/*
  double p = 1.;
  for( double i = 0; i < m; ++i){
    p *= (x - i); }
  return p ;
  */
  return boost::math::falling_factorial(x, static_cast<unsigned int>(m));
}


@  {\bf [[veldi]] $x^{y}$}


compute $x^{y}$ checking for under- and overflows


<<deltanull-poissondirichlet-varyingN.c>>=
static double veldi (const double x, const double y )
  {
    feclearexcept (FE_ALL_EXCEPT);
    const double d = pow (x,y);

    return (fetestexcept (FE_UNDERFLOW) ? 0. : (fetestexcept(FE_OVERFLOW) ? FLT_MAX : d));
  }

@ {\bf [[lambdanks]]}

compute the coalescent rate \eqref{eq:1}

<<deltanull-poissondirichlet-varyingN.c>>=
static double lambdanks (const double n, const std::vector<unsigned int>& v_k,  const STIKAR& s__s, const FASTAR & s__f )
{
  assert(v_k[0] > 1);

  double d {};
  double k {} ;
  double f {1} ;
  const double r = static_cast<double>(v_k.size());
  
  std::unordered_map<unsigned int, unsigned int> counts {} ;
  
  for( std::size_t i = 0; i < v_k.size(); ++i){
    f *= descending_factorial( static_cast<double>(v_k[i]) - 1. - s__s.ALPHA,
                                        static_cast<double>(v_k[i]) -1);
    /* count occurrence of each  merger size */
    ++counts[v_k[i]];
    k += static_cast<double>(v_k[i]) ;
    d += lgamma(static_cast<double>(v_k[i] + 1)) ; }

  assert( k < n + 1 ); 
  const double s = n - k;
  
  const double p = static_cast<double>(std::accumulate( counts.begin(), counts.end(), 0,
               [](double a, const auto &x){ return a +  lgamma( (double)x.second + 1);}));
  
  const double l = ((v_k.size() < 2 ? (v_k[0] < 3 ? 1. : 0) : 0)*s__f.CKAPPA)
                   + (s__s.CEPS * veldi(s__s.ALPHA, r+s-1) * tgamma(r+s) * f/tgamma(n) ) ;
  
  return (veldi(exp(1), (lgamma( n + 1.) - d)  - lgamma( n - k + 1 ) - p) * l
                                            / (s__f.CKAPPA + (s__s.CEPS*(1.-s__s.ALPHA))));
}


@ [[generatecdf]] 

generate from the rates \eqref{eq:1} a cumulative mass function for
sampling mergers; assumes the possible mergers are in files {\tt
  gg\_<m>\_.txt} where [[m]] is the given number of blocks, one merger
size combination per line; the combinations can be in any order, the
rates will be sorted in descending order for an efficient sampling of
a combination


<<deltanull-poissondirichlet-varyingN.c>>=
static double generatecdf(const unsigned int m,
                          std::vector<double>& v__cdf,
			  std::vector<unsigned int>& v__idx,
			   const STIKAR& s__s,
			   const FASTAR& s__f)
{
  /* the cdf will be stored in v__cdf;   */
  std::string line {} ;

  /* count the number of possible merger combinations given m blocks,
                                the number of lines of gg_m_.txt */
  std::ifstream g("gg_" + std::to_string(m) + "_.txt") ;
  assert(g.is_open());
  const unsigned int numberlines = std::count(std::istreambuf_iterator<char>(g),
                                         std::istreambuf_iterator<char>(), '\n');
  g.close();
  std::vector<double> v__lambdam {} ;
  v__lambdam.clear();
  v__lambdam.reserve(numberlines);
  assert( v__lambdam.size()<1);
  
  std::vector<unsigned int>  v__mergers {};
  double totalrate {};
  /* read all mergers summing from 2 to  m blocks */
  
  std::ifstream f("gg_" + std::to_string(m) + "_.txt") ;
  assert(f.is_open());
  while( std::getline(f, line) )
    {
      v__mergers.clear();
      assert(v__mergers.size() < 1);
      std::stringstream ss(line);
      v__mergers = std::vector<unsigned int>(std::istream_iterator<unsigned int>(ss), {});
      assert(0 < v__mergers.size());
      /* compute rates and total rate */
      v__lambdam.push_back( lambdanks(static_cast<double>(m), v__mergers, s__s, s__f) );
      totalrate += v__lambdam.back();
    }
  f.close();
  std::vector<unsigned int>().swap(v__mergers) ;
  assert(0 < v__lambdam.size() ) ;
  assert(std::numeric_limits<double>::epsilon() < totalrate);

  /* sort into descending order */
  v__idx.clear();
  v__idx.resize(v__lambdam.size(),0);
  std::iota(v__idx.begin(),v__idx.end(),0);
  std::stable_sort(v__idx.begin(), v__idx.end(),
      [&v__lambdam](const unsigned int x, const unsigned int y)
                      {return v__lambdam[x] > v__lambdam[y];});

  /* normalise the rates with totalrate and store the result in v__cdf */ 
  v__cdf.clear();
  v__cdf.resize(v__lambdam.size());
  std::transform(v__lambdam.begin(), v__lambdam.end(), v__cdf.begin(),
                     [&totalrate](const double x){return x/totalrate;});

  assert(0 < v__cdf.size());
  v__lambdam.clear();
  v__lambdam.resize(0);
  std::vector<double>().swap(v__lambdam);
  /* need totalrate for given  m blocks  for sampling time */
  return totalrate;
}




@ [[generate_all_cdfs]]

compute all  rates for all numbers of blocks from 2 to sample size


<<deltanull-poissondirichlet-varyingN.c>>=
static void generate_all_cdfs (std::vector<std::vector<double>>& a__cdfs,
                               std::vector<std::vector<unsigned int>>& a__idx,
			       std::vector<double>& v__lambdam,
			        const STIKAR& s__s,
				const FASTAR &s__f)
{
  a__cdfs.push_back(std::vector<double>());
  a__cdfs.push_back(std::vector<double>());
  a__idx.push_back(std::vector<unsigned int>());
  a__idx.push_back(std::vector<unsigned int>());
  std::vector<double> tmpcdf {};
  std::vector<unsigned int> tmpidx {};
  for(unsigned int m = 2; m <= SAMPLE_SIZE; ++m)
    {
      v__lambdam[m] = generatecdf(m, tmpcdf, tmpidx, s__s, s__f);
      a__cdfs.push_back(tmpcdf);
      a__idx.push_back(tmpidx);
    }

  assert(a__cdfs.size() == SAMPLE_SIZE + 1);
  assert(a__idx.size() == SAMPLE_SIZE + 1);
  
  tmpcdf.clear();
  tmpcdf.resize(0);
  std::vector<double>().swap(tmpcdf);
  tmpidx.clear();
  tmpidx.resize(0);
  std::vector<unsigned int>().swap(tmpidx);
}



@ [[sample_merger]]


sample a merger size combination 

<<deltanull-poissondirichlet-varyingN.c>>=
static unsigned int sample_merger(const std::vector<double>& v__f,
                          const std::vector<unsigned int>& v__sidx)
{
  unsigned int j {};
  assert( v__f[v__sidx[j]] <= 1.);
  double f = v__f[v__sidx[j]];
  const double u = gsl_rng_uniform_pos(rngtype);
  /* add the normalised combination rates  in descending order */
  while( f < u ){++j; f += v__f[v__sidx[j]]; };
  /* return the line number  corresponding to sampled combination */
  return v__sidx[j] + 1;
}


@ [[readmergersizes]]


read the sampled combination of merger sizes 


<<deltanull-poissondirichlet-varyingN.c>>=
static void readmergersizes(const unsigned int linenumber,
                            const unsigned int m,
			    std::vector<unsigned int>& v__mergers)
{
  /* m is the number of blocks */
  /* linenumber corresponds to the sampled combination */
  
  std::ifstream f("gg_" + std::to_string(m) + "_.txt") ;
  std::string line {} ;

  v__mergers.clear();
  assert(v__mergers.size() < 1);
  
  for( unsigned int i = 0; std::getline(f, line) && i < linenumber; ++i ){
    if(i >= linenumber-1 ){
      
      std::stringstream ss(line) ;
      v__mergers = std::vector<unsigned int>( std::istream_iterator<unsigned int>(ss), {} );
    } }
    
/* v__mergers stores the merger sizes of the sampled combination */
  assert(v__mergers.size() > 0) ;
  assert(v__mergers[0] > 1);
  assert(v__mergers.back() > 1);
  f.close();
}


@ [[updatetree]]

update corrent configuration of block sizes by merging blocks
according to the sampled combination


<<deltanull-poissondirichlet-varyingN.c>>=
static void  updatetree (std::vector<unsigned int> & tre,
                        const std::vector<unsigned int>& mergersizes)
{
  /* tre is current block sizes */
  /* mergersizes is sampled merger size(s) */
  assert( mergersizes.size() > 0) ;

  std::vector< unsigned int> newblocks {};
  newblocks.clear() ;
  newblocks.reserve(mergersizes.size());
  std::shuffle( tre.begin(), tre.end(), rng) ;
  std::size_t s = tre.size();
  for(const auto &k : mergersizes)
    {
      assert( k > 1);
      assert( k <= s) ;
      s -= k ;
      /* record the size of the merging blocks */
      newblocks.push_back( std::accumulate( tre.rbegin(), tre.rbegin() + k, 0));
      /* remove the blocks that merged */
      tre.resize(s);
    }
  assert (newblocks.size() == mergersizes.size()) ;
  assert (static_cast<unsigned int>(std::accumulate( newblocks.begin(), newblocks.end(), 0))
                                                                             <= SAMPLE_SIZE);
  
  tre.insert (tre.end(), newblocks.begin(), newblocks.end());

  assert (static_cast<unsigned int>(std::accumulate( tre.begin(), tre.end(), 0))
                                                                 == SAMPLE_SIZE);
  newblocks.clear();
  newblocks.resize(0);
  std::vector<unsigned int>().swap(newblocks);
}



@  [[newtime]]


sample new length of  time interval; recall \eqref{eq:2} and \eqref{eq:3} for the time-changing

<<deltanull-poissondirichlet-varyingN.c>>=
double newtime (const double lambdab,  const double oldtime, const STIKAR& s__s)
{

  /* RHO > 0 then population growth forward in time with parameter |RHO| */
  auto gtimi = [&s__s](const double o, const double l)
  {
       assert(std::numeric_limits<double>::epsilon() < s__s.RHO);
     std::feclearexcept(FE_ALL_EXCEPT);
     const double e = exp(- s__s.RHO * o);
     
     return(std::fetestexcept(FE_UNDERFLOW) ? 0.
                  : log1p(- e * s__s.RHO * log(gsl_rng_uniform_pos(rngtype)) / l)
		                                                      / s__s.RHO);
  } ;


  /* RHO < 0 then population decline forward in time with parameter |RHO| */
  auto dtimi = [&s__s](const double o, const double l)
  {
      assert(s__s.RHO < 0. ) ;
     std::feclearexcept(FE_ALL_EXCEPT);
     const double e = exp(- fabs(s__s.RHO) * o );

     return(o + log( (fetestexcept(FE_UNDERFLOW) ? 0. :e)
            - ( fabs(s__s.RHO) * log(gsl_rng_uniform_pos(rngtype))/l)) / fabs(s__s.RHO));
  };
  
  return (fabs(s__s.RHO) > std::numeric_limits<double>::epsilon() ?
         (s__s.RHO < 0. ? dtimi(oldtime, lambdab) : gtimi(oldtime,lambdab)) :
	                     gsl_ran_exponential (rngtype, 1./lambdab)) ;
}


@ [[genealogy]]


sample one `tree'   and record branch lengths 


<<deltanull-poissondirichlet-varyingN.c>>=
void genealogy (std::vector<double>& v__r__,
               const std::vector<double>& v__l__,
	       const std::vector<std::vector<double>>& a__cdfs,
	       const std::vector<std::vector<unsigned int>>& a__sidxs,
	       const STIKAR& s__s)
{
  /* n is sample size */
  assert(SAMPLE_SIZE > 1) ;
  std::vector<unsigned int> tre (SAMPLE_SIZE, 1) ;
  std::vector<double> b__ (SAMPLE_SIZE) ;
  std::vector<double> r__ (SAMPLE_SIZE) ;
  std::vector<double> f__ {};
  std::vector<unsigned int> m__ {} ;
  auto update_branch_lengths = [&b__,&tre](const double s)
  { /* s is the sampled interval time*/
    for(const auto &z: tre)
      {
	b__[0] += s;
	b__[z] += s;}
  };

  double t {};
  double trate {} ;
  double tau {} ;
  unsigned int lina {} ;
  while(tre.size() > 1)
    {
      /* sample interval time with current number of blocks */
      t = newtime(v__l__[tre.size()], tau, s__s);
      assert(0. <= t);
      tau += t;
      /* update current branch lengths */
      update_branch_lengths(t);
      /* sample mergers */
      lina = sample_merger(a__cdfs[tre.size()], a__sidxs[tre.size()]);
      /* read in merger sizes corresponding to line number lina */
      readmergersizes(lina, tre.size(), m__);
      /* merge blocks and update tree */
      updatetree(tre, m__);
    }
  /* update relative branch lengths */
  assert(std::numeric_limits<double>::epsilon() <  b__[0]  );
  const double s = b__[0];
  std::transform(b__.begin(), b__.end(), v__r__.begin(), v__r__.begin(),
                  [&s](const auto &x, const auto &y){return y + (x/s);});
}


@ [[approximate]]


go ahead -- approximate $\EE{R_{i}(n)}$ 


<<deltanull-poissondirichlet-varyingN.c>>=
void approximate (const double c__alpha, const double c__kappa, const double c__ceps, const double c__rho)
{

  STIKAR s_s (c__alpha, c__kappa, c__ceps, c__rho);
  FASTAR s_f = {.MINF = (2. + (1 + pow(2., 1-s_s.KAPPA)/(s_s.KAPPA - 1)))/2.,
    .BKAPPA = pow(2,s_s.KAPPA)*(s_s.KAPPA - 2)*(s_s.KAPPA - 1),
    .AKAPPA = ((s_s.KAPPA+2) + pow(s_s.KAPPA,2))/2.,
    .CKAPPA = (s_s.KAPPA > 2 ? s_f.AKAPPA / s_f.BKAPPA : 1.) * 2./pow(s_f.MINF,2.)} ;
  

  std::vector<double> ri__ (SAMPLE_SIZE);
  std::vector<double> v__l (SAMPLE_SIZE);
  int r = static_cast<int>(EXPERIMENTS) +1;

  std::vector< std::vector<double>> a__cdfs__ {};
  std::vector<std::vector<unsigned int>> a__idx__ {};

  /* generate cdfs for block numbers 2 to sample size; sort indexes */
  generate_all_cdfs(a__cdfs__, a__idx__, v__l, s_s, s_f);

  /* generate EXPERIMENTS number of trees and read branch lengths */
  while(--r > 0)
    { genealogy(ri__, v__l,  a__cdfs__, a__idx__ , s_s); }
  for(unsigned int j = 1; j < SAMPLE_SIZE; ++j)
    {std::cout << (std::numeric_limits<double>::epsilon() < ri__[j] ?
    (log(ri__[j]/(EXPERIMENTS)) - log1p(-ri__[j]/(EXPERIMENTS))) : 9999) << '\n';}

  v__l.clear();
  v__l.resize(0);
  std::vector<double>().swap(v__l);
  ri__.clear();
  ri__.resize(0);
  std::vector<double>().swap(ri__);

  a__cdfs__.clear();
  a__cdfs__.resize(0);
  std::vector< std::vector<double>>().swap(a__cdfs__);
  a__idx__.clear();
  a__cdfs__.resize(0);
  std::vector<std::vector<unsigned int>>().swap(a__idx__);
}




